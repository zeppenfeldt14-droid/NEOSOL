generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id               Int      @id @default(autoincrement())
  zona             String?
  subZona          String?
  rubro            String?
  ocultarVendedor  Boolean  @default(false)
  nombre           String   // Institución / Empresa
  cuit             String?
  direccion        String?  // Dirección de Entrega
  direccionFiscal  String?
  barrio           String?  // Localidad
  partido          String?
  telefono         String?  // TEL / Celular
  email            String?
  responsable      String?  // Contacto principal
  contactoCobranzas String?
  diasPago         String?
  vendedorAsignado String?
  actividad        String?
  productosInteres String?
  transporte       String?
  url              String?
  bancoInstitucion String?
  bancoSucursal    String?
  bancoCuenta      String?
  googleMaps       String?
  notas            String?
  estado           String   @default("prospecto")  // 'prospecto' | 'activo' | 'descartada' | 'baja'
  motivoBaja       String?  // Obligatorio cuando estado = 'baja'
  fechaBaja        DateTime?
  frecuenciaVisita Int?
  cicloVentaDias   Int?
  creadoEn         DateTime @default(now())
  actualizadoEn    DateTime @updatedAt

  // ── Plan Maestro: Customer 360 & Inteligencia Predictiva ──────────────────
  sentimentScore   Int?     // 0-100: umbral < 40 = alerta de churn (Zigpoll)
  latitud          Float?   // Coordenada para ruteo y geofencing
  longitud         Float?
  frecuenciaCompra Int?     // Compras/mes calculado — para alertas de upsell
  limiteCreditoARs Float?   // Límite de crédito aprobado en ARS
  saldoDeudorARs   Float?   @default(0) // Saldo deudor actual

  visitas         Visita[]
  acciones        Accion[]
  alertas         Alerta[]
  pedidos         Pedido[]
  ticketsSoporte  TicketSoporte[]
  notasPlanificador NotaPlanificador[]
}

model SubZona {
  id     Int    @id @default(autoincrement())
  zona   String // CABA, Zona SUR, Zona OESTE, Zona NORTE
  nombre String // CABA 1, CABA 2, OESTE 1, OESTE 2, etc.

  @@unique([zona, nombre])
}

model Rubro {
  id     Int    @id @default(autoincrement())
  nombre String @unique
}

model Visita {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  empresa       Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fecha         DateTime @default(now())
  tipo          String   @default("visita")   // 'visita' | 'correo' | 'whatsapp'
  resultado     String
  contacto      String?
  cargo         String?
  notas         String?
  proximaAccion String?
  creadoEn      DateTime @default(now())

  // ── Plan Maestro: Check-in/out Georeferenciado ────────────────────────────
  latitudCheckIn   Float?   // GPS del preventista al momento del check-in
  longitudCheckIn  Float?
  whatsappEnviado   Boolean  @default(false)
  respuestaObtenida Boolean  @default(false)
  exhibicion       String?  // Cualitativo: 'buena' | 'regular' | 'mala' | null
  usuarioAlias     String?  // Alias del vendedor que registró la visita
}

model Accion {
  id               Int       @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  tipo             String
  descripcion      String
  fechaVencimiento DateTime?
  prioridad        String    @default("media")
  estado           String    @default("pendiente")
  orden            Int       @default(0)
  completadaEn     DateTime?
  creadoEn         DateTime  @default(now())
}

model Alerta {
  id                Int       @id @default(autoincrement())
  empresaId         Int
  empresa           Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  tipo              String
  mensaje           String?
  diasConfiguracion Int?
  fechaActivacion   DateTime?
  activa            Boolean   @default(true)
  creadoEn          DateTime  @default(now())
}

model ConfiguracionSistema {
  id          Int    @id @default(autoincrement())
  clave       String @unique
  valor       String
  descripcion String?
}

model Usuario {
  id                    Int      @id @default(autoincrement())
  nombre                String
  alias                 String   @unique
  email                 String   @unique
  passwordHash          String
  nivel                 Int      @default(3) // 1 = Gerencia/Admin, 2 = Supervisión, 3 = Ventas/Vendedores
  rol                   String   @default("Vendedor")
  foto                  String?  // Avatar en Base64 o URL
  activo                Boolean  @default(true)
  modulos               Json     @default("{}") // Mapeo de permisos por módulo
  limitesEstado         Json     @default("{}") // Límites de tiempo para pausas
  mustChangePassword    Boolean  @default(false)
  loginCount            Int      @default(0)
  connectionLogs        Json     @default("[]") // Historial de últimas 20 conexiones
  zona                  String?  @default("CABA") // Zona asignada para Nivel 3
  zonasHabilitadas      Json     @default("[]")   // Zonas permitidas para Nivel 2/1
  passwordUpdatedAt     DateTime?
  creadoEn              DateTime @default(now())
  actualizadoEn         DateTime @updatedAt
}

model LogBitacora {
  id           Int      @id @default(autoincrement())
  usuarioId    Int?
  usuarioAlias String   @default("Sistema")
  tipoAccion   String   // LOGIN, LOGOUT, CREATE_USER, etc.
  detalles     String
  creadoEn     DateTime @default(now())
}

model SolicitudEliminacion {
  id            Int      @id @default(autoincrement())
  tipo          String   // 'EMPRESA' | 'ACCION'
  targetId      Int
  nombreTarget  String
  solicitadoPor String
  motivo        String
  creadoEn      DateTime @default(now())
  estado        String   @default("pendiente") // 'pendiente' | 'aprobado' | 'rechazado'
}

model Zona {
  id       Int      @id @default(autoincrement())
  nombre   String   @unique
  creadoEn DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// MÓDULO COMERCIAL: Productos, Pedidos, Ventas y Cobranzas
// ─────────────────────────────────────────────────────────────────────────────

model Producto {
  id              Int      @id @default(autoincrement())
  codigoInterno   String   @unique
  nombre          String
  linea           String?  // 'pack_individual' | 'tripack' | 'minis' | 'snacks'
  precioPaquete   Float    // Precio x paquete (sin IVA)
  paqPorCaja      Int      // Paquetes por caja
  precioCaja      Float    // Precio x caja (sin IVA)
  activo          Boolean  @default(true)
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  detallesPedido DetallePedido[]
  detallesPromocion DetallePromocion[]
}

model Promocion {
  id          Int      @id @default(autoincrement())
  nombre      String   // Ej: "10x1 Sándwich"
  descripcion String?
  tipo        String   @default("bonificacion") // 'bonificacion' | 'descuento_porcentaje' | 'precio_especial'
  // Para 10x1: compraMinima=10, bonificacion=1
  compraMinima    Int?   // Cantidad mínima para aplicar la promo
  bonificacion    Int?   // Unidades obsequiadas
  descuento       Float? // Porcentaje de descuento si aplica
  activa          Boolean  @default(true)
  vigenciaDesde   DateTime?
  vigenciaHasta   DateTime?
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  detallesPromocion DetallePromocion[]
}

model DetallePromocion {
  id         Int      @id @default(autoincrement())
  promocion  Promocion @relation(fields: [promocionId], references: [id])
  promocionId Int
  producto   Producto  @relation(fields: [productoId], references: [id])
  productoId  Int
}

model Pedido {
  id              Int      @id @default(autoincrement())
  numeroPedido    String   @unique // Generado automáticamente, ej: PED-2026-001
  empresaId       Int
  empresa         Empresa  @relation(fields: [empresaId], references: [id])
  vendedorId      Int
  vendedorAlias   String
  zona            String
  
  // Estado del flujo
  estado          String   @default("borrador")
  // 'borrador' | 'pendiente_supervisor' | 'aprobado' | 'cancelado'
  
  tienePrecioNegociado Boolean @default(false)
  tieneTarifaNegociada Boolean @default(false)
  
  // Condiciones de negociación
  porcentajePagoA Float    @default(20)  // % que va con IVA (Factura A)
  porcentajePagoB Float    @default(80)  // % que va sin IVA (Factura B / Remito)
  aplicaFinanciera Boolean @default(false)
  // Plazos de pago (texto libre, ej: "30 días / 60 días")
  plazosPago      String?
  condicionPago   String?  // Ej: "20/80", "50/50", "100% A", personalizada

  metodoPagoA     String?  // 'cheque' | 'transferencia'
  fechaPagoA      DateTime?
  metodoPagoB     String?  // 'efectivo' | 'transferencia'
  
  // Totales calculados
  subtotalSinIVA  Float    @default(0)
  montoIVA        Float    @default(0)  // 21% sobre la parte A
  montoFinanciera Float    @default(0)  // 3% sobre la parte que aplica
  totalGeneral    Float    @default(0)
  
  // Promoción aplicada
  promocionId     Int?
  
  observaciones   String?
  acuerdosComerciales String?
  requierePresupuesto Boolean @default(false)
  turnoEntrega    String?  // 'SI' | 'NO'
  fechaEntrega    String?  // Fecha/Día de entrega acordado
  
  // Auditoría
  aprobadoPorId   Int?
  aprobadoPorAlias String?
  aprobadoEn      DateTime?
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt
  
  detalles    DetallePedido[]
  facturas    Factura[]
  cobranzas   Cobranza[]
}

model DetallePedido {
  id          Int      @id @default(autoincrement())
  pedidoId    Int
  pedido      Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId  Int
  producto    Producto @relation(fields: [productoId], references: [id])
  
  // Snapshot de precios al momento del pedido
  productoNombre    String
  precioCajaSnapshot Float
  precioPaqSnapshot  Float
  paqPorCajaSnapshot Int
  precioCajaOriginal Float @default(0)
  
  cantidadCajas   Int      @default(0)
  subtotal        Float    @default(0) // cantidadCajas * precioCajaSnapshot
  
  // Bonificación 10x1 u otro tipo
  cajasBonus      Int      @default(0)
  descripcionBonus String?
}

model Factura {
  id            Int      @id @default(autoincrement())
  pedidoId      Int
  pedido        Pedido   @relation(fields: [pedidoId], references: [id])
  numeroFactura String   @unique // Ej: FAC-A-2026-001
  tipo          String   // 'A' | 'B' | 'remito'
  
  // Archivo PDF / Imagen adjunto
  archivoBase64 String?  // Base64 text of the uploaded PDF or image
  archivoMimeType String? // e.g., 'application/pdf', 'image/jpeg'

  // Montos
  subtotal      Float
  iva           Float    @default(0)  // Solo si tipo='A'
  recargo       Float    @default(0)  // 3% financiera si aplica
  total         Float
  
  estado        String   @default("pendiente") // 'pendiente' | 'pagada' | 'parcial' | 'anulada'
  
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  
  pagos         Pago[]
}

model Cobranza {
  id              Int      @id @default(autoincrement())
  pedidoId        Int
  pedido          Pedido   @relation(fields: [pedidoId], references: [id])
  empresaId       Int
  empresaNombre   String
  vendedorAlias   String
  zona            String
  
  // Montos
  montoOriginal   Float
  saldoPendiente  Float
  
  // Plazos
  cuota           Int      @default(1)  // Número de cuota
  totalCuotas     Int      @default(1)
  estado          String   @default("pendiente") // 'pendiente' | 'pagada' | 'vencida' | 'parcial'
  fechaVencimiento DateTime?
  tipoFactura    String?  // 'A' o 'B'
  metodoPago     String?  // 'cheque', 'transferencia', 'efectivo'
  
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt
  
  pagos           Pago[]
}

model Pago {
  id            Int      @id @default(autoincrement())
  cobranzaId    Int?
  cobranza      Cobranza? @relation(fields: [cobranzaId], references: [id])
  facturaId     Int?
  factura       Factura?  @relation(fields: [facturaId], references: [id])
  
  monto         Float
  metodoPago    String   // 'efectivo' | 'transferencia' | 'cheque' | 'financiera'
  recargoAplicado Float  @default(0) // 3% si es financiera
  montoFinal    Float    // monto + recargoAplicado
  
  referencia    String?  // Número de cheque, comprobante, etc.
  notas         String?
  registradoPorAlias String
  
  creadoEn      DateTime @default(now())
}

model ListaPrecio {
  id           Int              @id @default(autoincrement())
  nombre       String
  vigenteDesde DateTime
  activa       Boolean          @default(true)
  creadoEn     DateTime         @default(now())
  
  precios      PrecioProducto[]
}

model PrecioProducto {
  id               Int         @id @default(autoincrement())
  listaId          Int
  lista            ListaPrecio @relation(fields: [listaId], references: [id], onDelete: Cascade)
  productoId       Int
  productoCodigo   String      // For fast matching
  
  // Pricing for under 300 boxes
  precioPaqueteMin Float
  precioCajaMin    Float
  
  // Pricing for 300 boxes or more
  precioPaqueteMax Float
  precioCajaMax    Float
  
  creadoEn         DateTime    @default(now())

  @@unique([listaId, productoId])
}

model ReporteVisitas {
  id            Int      @id @default(autoincrement())
  fecha         String   // Formato 'DD-MM-YYYY'
  zona          String   // Ej: 'CABA'
  vendedorAlias String   // Ej: 'Ernesto Lares'
  datosJSON     String   // Instantánea estructurada de visitas y notas del día (JSON String)
  creadoEn      DateTime @default(now())

  @@unique([fecha, zona])
}

// ─────────────────────────────────────────────────────────────────────────────
// MÓDULO CRM 360: Tickets de Soporte y Engagement Tracking
// ─────────────────────────────────────────────────────────────────────────────

model TicketSoporte {
  id          Int       @id @default(autoincrement())
  empresaId   Int
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  tipo        String    // 'entrega' | 'calidad' | 'facturacion' | 'otro'
  prioridad   String    @default("media")  // 'alta' | 'media' | 'baja'
  estado      String    @default("abierto") // 'abierto' | 'en_proceso' | 'resuelto' | 'cerrado'

  asunto      String
  descripcion String
  resolucion  String?

  reportadoPorAlias String?
  asignadoA         String?  // Alias del responsable interno

  creadoEn    DateTime  @default(now())
  cerradoEn   DateTime?
  actualizadoEn DateTime @updatedAt
}
model NotaPlanificador {
  id               Int       @id @default(autoincrement())
  texto            String
  empresaId        Int?
  empresa          Empresa?  @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  destinatario     String    @default("personal") // 'personal' | 'gerencia' | 'asistente'
  estado           String    @default("pendiente") // 'pendiente' | 'completada'
  zona             String
  creadoPor        String?
  creadoEn         DateTime  @default(now())
}
