generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                Int                @id @default(autoincrement())
  zona              String?
  nombre            String
  cuit              String?
  direccion         String?
  direccionFiscal   String?
  barrio            String?
  partido           String?
  telefono          String?
  email             String?
  responsable       String?
  contactoCobranzas String?
  diasPago          String?
  vendedorAsignado  String?
  actividad         String?
  productosInteres  String?
  transporte        String?
  url               String?
  googleMaps        String?
  notas             String?
  estado            String             @default("prospecto")
  motivoBaja        String?
  fechaBaja         DateTime?
  frecuenciaVisita  Int?
  cicloVentaDias    Int?
  creadoEn          DateTime           @default(now())
  actualizadoEn     DateTime           @updatedAt
  ocultarVendedor   Boolean            @default(false)
  subZona           String?
  frecuenciaCompra  Int?
  latitud           Float?
  limiteCreditoARs  Float?
  longitud          Float?
  saldoDeudorARs    Float?             @default(0)
  sentimentScore    Int?
  rubro             String?
  bancoCuenta       String?
  bancoInstitucion  String?
  bancoSucursal     String?
  telefono2         String?
  acciones          Accion[]
  alertas           Alerta[]
  notasPlanificador NotaPlanificador[]
  pedidos           Pedido[]
  ticketsSoporte    TicketSoporte[]
  visitas           Visita[]
}

model SubZona {
  id     Int    @id @default(autoincrement())
  zona   String
  nombre String

  @@unique([zona, nombre])
}

model Rubro {
  id     Int    @id @default(autoincrement())
  nombre String @unique
}

model Visita {
  id                Int      @id @default(autoincrement())
  empresaId         Int
  fecha             DateTime @default(now())
  tipo              String   @default("visita")
  resultado         String
  contacto          String?
  cargo             String?
  notas             String?
  proximaAccion     String?
  creadoEn          DateTime @default(now())
  exhibicion        String?
  latitudCheckIn    Float?
  longitudCheckIn   Float?
  usuarioAlias      String?
  whatsappEnviado   Boolean  @default(false)
  respuestaObtenida Boolean  @default(false)
  empresa           Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model Accion {
  id               Int       @id @default(autoincrement())
  empresaId        Int
  tipo             String
  descripcion      String
  fechaVencimiento DateTime?
  prioridad        String    @default("media")
  estado           String    @default("pendiente")
  orden            Int       @default(0)
  completadaEn     DateTime?
  creadoEn         DateTime  @default(now())
  empresa          Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model Alerta {
  id                Int       @id @default(autoincrement())
  empresaId         Int
  tipo              String
  mensaje           String?
  diasConfiguracion Int?
  fechaActivacion   DateTime?
  activa            Boolean   @default(true)
  creadoEn          DateTime  @default(now())
  empresa           Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model ConfiguracionSistema {
  id          Int     @id @default(autoincrement())
  clave       String  @unique
  valor       String
  descripcion String?
}

model Usuario {
  id                 Int       @id @default(autoincrement())
  nombre             String
  alias              String    @unique
  email              String    @unique
  passwordHash       String
  nivel              Int       @default(3)
  rol                String    @default("Vendedor")
  foto               String?
  activo             Boolean   @default(true)
  modulos            Json      @default("{}")
  limitesEstado      Json      @default("{}")
  mustChangePassword Boolean   @default(false)
  loginCount         Int       @default(0)
  connectionLogs     Json      @default("[]")
  passwordUpdatedAt  DateTime?
  creadoEn           DateTime  @default(now())
  actualizadoEn      DateTime  @updatedAt
  zona               String?   @default("CABA")
  zonasHabilitadas   Json      @default("[]")
}

model LogBitacora {
  id           Int      @id @default(autoincrement())
  usuarioId    Int?
  usuarioAlias String   @default("Sistema")
  tipoAccion   String
  detalles     String
  creadoEn     DateTime @default(now())
}

model SolicitudEliminacion {
  id            Int      @id @default(autoincrement())
  tipo          String
  targetId      Int
  nombreTarget  String
  solicitadoPor String
  motivo        String
  creadoEn      DateTime @default(now())
  estado        String   @default("pendiente")
}

model Zona {
  id       Int      @id @default(autoincrement())
  nombre   String   @unique
  creadoEn DateTime @default(now())
  barrios  String[] @default([])
  color    String?  @default("#3b82f6")
  geojson  Json?
}

model Producto {
  id                Int                @id @default(autoincrement())
  codigoInterno     String             @unique
  nombre            String
  linea             String?
  precioPaquete     Float
  paqPorCaja        Int
  precioCaja        Float
  activo            Boolean            @default(true)
  creadoEn          DateTime           @default(now())
  actualizadoEn     DateTime           @updatedAt
  detallesPedido    DetallePedido[]
  detallesPromocion DetallePromocion[]
}

model Promocion {
  id                Int                @id @default(autoincrement())
  nombre            String
  descripcion       String?
  tipo              String             @default("bonificacion")
  compraMinima      Int?
  bonificacion      Int?
  descuento         Float?
  activa            Boolean            @default(true)
  vigenciaDesde     DateTime?
  vigenciaHasta     DateTime?
  creadoEn          DateTime           @default(now())
  actualizadoEn     DateTime           @updatedAt
  detallesPromocion DetallePromocion[]
}

model DetallePromocion {
  id          Int       @id @default(autoincrement())
  promocionId Int
  productoId  Int
  producto    Producto  @relation(fields: [productoId], references: [id])
  promocion   Promocion @relation(fields: [promocionId], references: [id])
}

model Pedido {
  id                   Int                @id @default(autoincrement())
  numeroPedido         String             @unique
  empresaId            Int
  vendedorId           Int
  vendedorAlias        String
  zona                 String
  estado               String             @default("borrador")
  porcentajePagoA      Float              @default(20)
  porcentajePagoB      Float              @default(80)
  aplicaFinanciera     Boolean            @default(false)
  plazosPago           String?
  condicionPago        String?
  subtotalSinIVA       Float              @default(0)
  montoIVA             Float              @default(0)
  montoFinanciera      Float              @default(0)
  totalGeneral         Float              @default(0)
  promocionId          Int?
  observaciones        String?
  acuerdosComerciales  String?
  requierePresupuesto  Boolean            @default(false)
  turnoEntrega         String?
  aprobadoPorId        Int?
  aprobadoPorAlias     String?
  aprobadoEn           DateTime?
  creadoEn             DateTime           @default(now())
  actualizadoEn        DateTime           @updatedAt
  tienePrecioNegociado Boolean            @default(false)
  tieneTarifaNegociada Boolean            @default(false)
  fechaEntrega         String?
  fechaPagoA           DateTime?
  metodoPagoA          String?
  metodoPagoB          String?
  cobranzas            Cobranza[]
  detalles             DetallePedido[]
  facturas             Factura[]
  notasPlanificador    NotaPlanificador[]
  empresa              Empresa            @relation(fields: [empresaId], references: [id])
}

model DetallePedido {
  id                 Int      @id @default(autoincrement())
  pedidoId           Int
  productoId         Int
  productoNombre     String
  precioCajaSnapshot Float
  precioPaqSnapshot  Float
  paqPorCajaSnapshot Int
  cantidadCajas      Int      @default(0)
  subtotal           Float    @default(0)
  cajasBonus         Int      @default(0)
  descripcionBonus   String?
  precioCajaOriginal Float    @default(0)
  pedido             Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto           Producto @relation(fields: [productoId], references: [id])
}

model Factura {
  id                Int                @id @default(autoincrement())
  pedidoId          Int
  numeroFactura     String             @unique
  tipo              String
  subtotal          Float
  iva               Float              @default(0)
  recargo           Float              @default(0)
  total             Float
  estado            String             @default("pendiente")
  creadoEn          DateTime           @default(now())
  actualizadoEn     DateTime           @updatedAt
  archivoBase64     String?
  archivoMimeType   String?
  pedido            Pedido             @relation(fields: [pedidoId], references: [id])
  notasPlanificador NotaPlanificador[]
  pagos             Pago[]
}

model Cobranza {
  id                Int                @id @default(autoincrement())
  pedidoId          Int
  empresaId         Int
  empresaNombre     String
  vendedorAlias     String
  zona              String
  montoOriginal     Float
  saldoPendiente    Float
  cuota             Int                @default(1)
  totalCuotas       Int                @default(1)
  fechaVencimiento  DateTime?
  estado            String             @default("pendiente")
  creadoEn          DateTime           @default(now())
  actualizadoEn     DateTime           @updatedAt
  metodoPago        String?
  tipoFactura       String?
  pedido            Pedido             @relation(fields: [pedidoId], references: [id])
  notasPlanificador NotaPlanificador[]
  pagos             Pago[]
}

model Pago {
  id                 Int       @id @default(autoincrement())
  cobranzaId         Int?
  facturaId          Int?
  monto              Float
  metodoPago         String
  recargoAplicado    Float     @default(0)
  montoFinal         Float
  referencia         String?
  notas              String?
  registradoPorAlias String
  creadoEn           DateTime  @default(now())
  cobranza           Cobranza? @relation(fields: [cobranzaId], references: [id])
  factura            Factura?  @relation(fields: [facturaId], references: [id])
}

model ListaPrecio {
  id           Int              @id @default(autoincrement())
  nombre       String
  vigenteDesde DateTime
  activa       Boolean          @default(true)
  creadoEn     DateTime         @default(now())
  precios      PrecioProducto[]
}

model PrecioProducto {
  id               Int         @id @default(autoincrement())
  listaId          Int
  productoId       Int
  productoCodigo   String
  precioPaqueteMin Float
  precioCajaMin    Float
  precioPaqueteMax Float
  precioCajaMax    Float
  creadoEn         DateTime    @default(now())
  lista            ListaPrecio @relation(fields: [listaId], references: [id], onDelete: Cascade)

  @@unique([listaId, productoId])
}

model ReporteVisitas {
  id            Int      @id @default(autoincrement())
  fecha         String
  zona          String
  vendedorAlias String
  datosJSON     String
  creadoEn      DateTime @default(now())

  @@unique([fecha, zona])
}

model TicketSoporte {
  id                Int       @id @default(autoincrement())
  empresaId         Int
  tipo              String
  prioridad         String    @default("media")
  estado            String    @default("abierto")
  asunto            String
  descripcion       String
  resolucion        String?
  reportadoPorAlias String?
  asignadoA         String?
  creadoEn          DateTime  @default(now())
  cerradoEn         DateTime?
  actualizadoEn     DateTime  @updatedAt
  empresa           Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model NotaPlanificador {
  id                Int       @id @default(autoincrement())
  texto             String
  empresaId         Int?
  destinatario      String    @default("personal")
  estado            String    @default("pendiente")
  zona              String
  creadoPor         String?
  creadoEn          DateTime  @default(now())
  fechaRecordatorio DateTime?
  recordatorioVisto Boolean   @default(false)
  cobranzaId        Int?
  facturaId         Int?
  pedidoId          Int?
  cobranza          Cobranza? @relation(fields: [cobranzaId], references: [id])
  empresa           Empresa?  @relation(fields: [empresaId], references: [id])
  factura           Factura?  @relation(fields: [facturaId], references: [id])
  pedido            Pedido?   @relation(fields: [pedidoId], references: [id])
}
